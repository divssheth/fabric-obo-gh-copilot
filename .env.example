# =============================================================================
# Fabric OBO — Multi-Orchestrator Configuration
# Copy to .env and fill in your values.
# =============================================================================

# Azure App Registration (Backend service principal)
AZURE_CLIENT_ID=your-backend-app-client-id
AZURE_TENANT_ID=your-tenant-id

# OBO credential contract
# - local: can use OBO_CLIENT_SECRET for local dev only
# - production: leave OBO_CLIENT_SECRET empty and set UAMI_CLIENT_ID
# ENVIRONMENT values: local | production
ENVIRONMENT=local
UAMI_CLIENT_ID=your-user-assigned-managed-identity-client-id
OBO_CLIENT_SECRET=your-backend-app-client-secret

# Fabric / Power BI
FABRIC_WORKSPACE_ID=your-fabric-workspace-id
FABRIC_DATASET_ID=your-semantic-model-dataset-id

# =============================================================================
# Copilot SDK Backend (backend_gh/)
# =============================================================================

# COPILOT_AUTH_MODE values: pat | byok
COPILOT_AUTH_MODE=pat

# PAT mode (default) — requires GitHub token with Copilot access
GITHUB_TOKEN=your-github-token

# BYOK mode — uses Azure OpenAI (set COPILOT_AUTH_MODE=byok)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_MODEL=gpt-4o

# =============================================================================
# MAF Backend (backend_maf/)
# =============================================================================

# No API key required. Authentication uses Entra ID (DefaultAzureCredential):
#   - Local: uses your `az login` session automatically
#   - Production: uses Managed Identity on the compute (e.g., ACA)
# Ensure the identity has "Azure AI Developer" or "Cognitive Services OpenAI User"
# role on the Foundry project.
FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
FOUNDRY_MODEL=gpt-4o

# =============================================================================
# OBO MCP Server
# =============================================================================

# OBO MCP Server routing (confused-deputy guard)
OBO_MCP_SERVER_NAME=fabric-obo
OBO_MCP_SERVER_URL=http://localhost:8002/mcp
# AUTH_MODE values: user_delegated
AUTH_MODE=user_delegated

# Token validation expectations for mcp_server_obo
OBO_API_CLIENT_ID=your-backend-app-client-id
OBO_REQUIRED_SCOPE=access_as_user

# =============================================================================
# Frontend
# =============================================================================

# Frontend (for CORS + runtime config endpoint)
FRONTEND_ORIGIN=http://localhost:5500
FRONTEND_BACKEND_URL=http://localhost:8000

# Public frontend MSAL config (served by /client-config — no secrets)
FRONTEND_MSAL_CLIENT_ID=your-frontend-app-client-id
FRONTEND_MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
FRONTEND_MSAL_REDIRECT_URI=http://localhost:5500/frontend/index.html
FRONTEND_API_SCOPE=api://your-backend-app-client-id/access_as_user
